# Base de datos
DATABASE_URL=postgresql://devuser:devpass@localhost:5433/home_manager?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters
JWT_EXPIRATION_HOURS=24

# Usuarios iniciales (solo desarrollo)
OWNER_EMAIL=owner@home.local
OWNER_PASSWORD=owner-password
PARTNER_EMAIL=partner@home.local
PARTNER_PASSWORD=partner-password

# API
API_URL=http://localhost:8080
PORT=8080
ENV=development

# Redis (opcional para MVP)
REDIS_URL=redis://localhost:6380

# Email (opcional)
EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com
